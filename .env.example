# SQLite database (local dev). For serverless deploys, swap to Postgres URL.
DATABASE_URL="file:./dev.db"
APP_URL="http://localhost:3000"

# BigCommerce — server-side only, never expose to the browser
# demo | dry_run | live. With creds present, defaults to dry_run unless set to live.
SCUBAPIX_MODE="demo"
BIGCOMMERCE_STORE_HASH=""
BIGCOMMERCE_ACCESS_TOKEN=""
BIGCOMMERCE_CHANNEL_ID="1"

# SMTP — server-side only
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Scubapix <info@scubapix.com>"
